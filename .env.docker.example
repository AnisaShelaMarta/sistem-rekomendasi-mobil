# Docker Environment Variables
# Copy ini ke .env dan isi dengan nilai secure

# ==========================================
# App Configuration
# ==========================================
APP_NAME="Sirek Mobil"
APP_ENV=production
APP_KEY=base64:GENERATE_DENGAN_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://sirekmobil.ta-ku.my.id

LOG_CHANNEL=stack
LOG_LEVEL=warn

# ==========================================
# Database
# ==========================================
# Generate strong passwords: openssl rand -base64 24
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sirekmobil_user
DB_PASSWORD=your_secure_db_password_here

# MySQL Root Password (separate from app user)
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# ==========================================
# Session & Cache
# ==========================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ==========================================
# Cloudflare Tunnel
# ==========================================
# Domain: sirekmobil.ta-ku.my.id
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
